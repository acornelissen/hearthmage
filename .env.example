# Copy to .env and fill in. .env is gitignored.
# All values are optional seeds: settings saved through the web UI (stored in
# the config file) win over these.

# Where the config lives; cached readings and schedules are stored beside it.
# For the systemd deploy this must point inside /opt/hearthmage (ProtectHome).
#HEARTHMAGE_CONFIG_FILE=/opt/hearthmage/config.json

# Hub address (or use the settings page / network scan in the UI).
HEARTHMAGE_BASE_IP=192.168.1.50
#HEARTHMAGE_HUB_PORT=6653

# Zone display names, id:name pairs.
#HEARTHMAGE_ZONE_NAMES=1:Living Room,2:Bedroom

# Bind deliberately. 0.0.0.0 is all interfaces; use a specific LAN IP, or
# 127.0.0.1 behind a reverse proxy, to limit exposure. Never expose to the net.
HEARTHMAGE_BIND=0.0.0.0
HEARTHMAGE_PORT=8080

# Optional: require a password to use the app (recommended on shared/untrusted
# networks). Leave unset to keep the app open on a trusted LAN.
#HEARTHMAGE_PASSWORD=change-me
# Session cookie signing key; auto-generated and stored if left unset.
#HEARTHMAGE_SECRET_KEY=

# Set to 1 to run with in-memory fake data (no hub needed).
HEARTHMAGE_FAKE=0

# Log verbosity: DEBUG, INFO, WARNING, ERROR.
#HEARTHMAGE_LOG_LEVEL=INFO

# Electricity unit price for energy cost estimates (per kWh).
#HEARTHMAGE_PRICE_PER_KWH=0.28

# Optional MQTT bridge to Home Assistant. Set the host to enable it (needs the
# mqtt extra: pip install -e ".[mqtt]"). HA and every integration must talk to
# THIS app over MQTT, never to the hub directly.
#HEARTHMAGE_MQTT_HOST=10.0.0.5
#HEARTHMAGE_MQTT_PORT=1883
#HEARTHMAGE_MQTT_USERNAME=hearth
#HEARTHMAGE_MQTT_PASSWORD=changeme
#HEARTHMAGE_MQTT_BASE_TOPIC=hearthmage
#HEARTHMAGE_MQTT_NODE_ID=hub
